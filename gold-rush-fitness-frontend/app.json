{
  "expo": {
    "name": "Oregon Trail Fitness",
    "slug": "oregon-trail-fitness",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "oregontrailfitness",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.oregontrailfitness",
      "infoPlist": {
        "NSMotionUsageDescription": "We use motion data to count your steps on the trail.",
        "NSHealthShareUsageDescription": "We use health data to track your wellness journey.",
        "NSHealthUpdateUsageDescription": "We update health data to record your trail progress."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a0f00",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.oregontrailfitness",
      "permissions": [
        "ACTIVITY_RECOGNITION"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1a0f00",
          "dark": {
            "backgroundColor": "#0a0600"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
